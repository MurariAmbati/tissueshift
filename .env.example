# TissueShift Environment Configuration
# Copy this file to .env and fill in your values

# HuggingFace (required for UNI model access)
HF_TOKEN=your_huggingface_token_here

# Weights & Biases (optional, for experiment tracking)
WANDB_API_KEY=your_wandb_key_here
WANDB_PROJECT=tissueshift

# Data directories
DATA_DIR=./data
FEATURES_DIR=./data/features
SLIDES_DIR=./data/slides
CHECKPOINTS_DIR=./checkpoints

# GDC API (no key needed for open-access data)
GDC_API_URL=https://api.gdc.cancer.gov

# Database (for leaderboard)
DATABASE_URL=sqlite:///./tissueshift.db

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
